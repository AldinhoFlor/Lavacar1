# Copie este arquivo para ".env.local" e preencha com os dados do seu projeto Supabase.
# A URL e as chaves ficam em: Supabase > Project Settings > API (ou Data API).

# Endereço (URL) do seu projeto Supabase, algo como https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (pode ficar no navegador; o acesso é protegido por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Modo sem login (uso pessoal, single-empresa)
# -----------------------------------------------------------------------------
# Com MODO_SEM_LOGIN=true o app NÃO pede login: quem tiver o link acessa os
# dados. Ideal para uso próprio de um único lava-rápido. Para vender a vários
# clientes, remova esta variável (ou deixe diferente de "true") — o app volta a
# exigir conta (Supabase Auth) e a isolar os dados por empresa via RLS.
MODO_SEM_LOGIN=true

# Chave "service_role" do Supabase (SECRETA — bypassa o RLS).
# Onde achar: Supabase > Project Settings > API > seção "Project API keys" >
# chave "service_role". É usada só no servidor, apenas quando MODO_SEM_LOGIN=true.
# NUNCA use o prefixo NEXT_PUBLIC_ nela e NUNCA a exponha no navegador.
SUPABASE_SERVICE_ROLE_KEY=
